# ─── AI Agent Configuration ──────────────────────────────────────────
# Claude (Anthropic) — used by the AI agent and test generator
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI — optional fallback for AI test generation
OPENAI_API_KEY=your_openai_key_here

# ─── Test Environment ────────────────────────────────────────────────
TEST_ENV=production
# BASE_URL=https://k11softwaresolutions.com
# API_URL=https://k11softwaresolutions-backend.onrender.com/api/login/
# TEST_TIMEOUT=10000
# BROWSER=chromium
# HEADLESS=true
# RETRY_ATTEMPTS=2

# ─── Debug & Logging ─────────────────────────────────────────────────
# K11_DEBUG=true
# AGENT_DEBUG=true
# LOG_LEVEL=info
# LOG_TO_FILE=true
# SCREENSHOT_ON_FAILURE=true
